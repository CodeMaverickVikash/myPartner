{
  "name": "mypartner",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --filter @mypartner/web dev",
    "dev:web": "pnpm --filter @mypartner/web dev",
    "dev:api": "pnpm --filter @mypartner/api dev",
    "dev:markdown": "pnpm --filter @mypartner/markdown-editor dev",
    "dev:notes": "pnpm --filter @mypartner/note-taking dev",
    "build": "pnpm --filter @mypartner/web build",
    "build:all": "pnpm -r --filter \"@mypartner/*\" build",
    "build:api": "pnpm --filter @mypartner/api build",
    "build:packages": "pnpm --filter \"./packages/*\" build",
    "start": "pnpm --filter @mypartner/web start",
    "start:api": "pnpm --filter @mypartner/api start",
    "lint": "pnpm --filter @mypartner/web lint",
    "typecheck": "pnpm -r --filter \"@mypartner/*\" typecheck",
    "docker:build": "docker build -t mypartner:local .",
    "docker:build:vercel": "docker build -f Dockerfile.vercel -t mypartner-vercel-build:local .",
    "docker:up": "docker compose up --build",
    "docker:vercel-build": "docker compose run --rm vercel-build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
