{
  "name": "markdown-viewer-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @markdown-viewer/web dev",
    "dev:api": "pnpm --filter @markdown-viewer/api dev",
    "build": "pnpm --filter @markdown-viewer/web build",
    "build:api": "pnpm --filter @markdown-viewer/api build",
    "start": "pnpm --filter @markdown-viewer/web start",
    "start:api": "pnpm --filter @markdown-viewer/api start",
    "lint": "pnpm --filter @markdown-viewer/web lint"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "ws": "^8.21.0"
  }
}
