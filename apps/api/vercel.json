{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @mypartner/api build",
  "engines": { "node": "20.x" },
  "functions": {
    "api/[...path].ts": {
      "runtime": "nodejs20.x",
      "includeFiles": "dist/**",
      "maxDuration": 30
    }
  }
}
